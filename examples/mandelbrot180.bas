10 REM MANDELBROT DEMO (320X180, 8BPP, 2X2 BLOCKS)
20 GFX MODE,180
30 GFX OVERLAY,255
40 GFX CLEAR
50 GFX STATUS
60 REM RENDER LOOP
70 FOR Y=0 TO 178 STEP 2
80 CY=(Y-90)/60
90 FOR X=0 TO 318 STEP 2
100 CX=(X-200)/100
110 A=0
120 B=0
130 I=0
140 AA=A*A-B*B+CX
150 B=2*A*B+CY
160 A=AA
170 I=I+1
180 IF A*A+B*B>4 THEN 210
190 IF I<32 THEN 140
200 I=32
210 C=I*7
220 IF C>255 THEN C=255
230 GFX RECT,X,Y,X+1,Y+1,C
240 NEXT X
250 NEXT Y
260 GFX CCLEAR
270 PRINT "PRESS ANY KEY"
280 GET K$:IF K$="" THEN 280
290 GFX RESET
300 END
