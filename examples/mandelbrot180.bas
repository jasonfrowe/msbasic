10 REM MANDELBROT DEMO (MODE 180, 2X2 BLOCKS)
20 GFX MODE,180
30 GFX CLEAR
40 FOR Y=0 TO 178 STEP 2
50 CY=(Y-90)/60
60 FOR X=0 TO 318 STEP 2
70 CX=(X-200)/100
80 A=0
90 B=0
100 I=0
110 AA=A*A-B*B+CX
120 B=2*A*B+CY
130 A=AA
140 I=I+1
150 IF A*A+B*B>4 THEN 180
160 IF I<32 THEN 110
170 I=32
180 C=I*7
190 IF C>255 THEN C=255
200 GFX RECT,X,Y,X+1,Y+1,C
210 NEXT X
220 NEXT Y
230 END
