10 REM MANDELBROT DEMO (MODE 240, 2X2 BLOCKS)
20 GFX M,240
30 GFX C
40 FOR Y=0 TO 238 STEP 2
50 CY=(Y-120)/80
60 FOR X=0 TO 318 STEP 2
70 CX=(X-200)/100
80 A=0
90 B=0
100 I=0
110 AA=A*A-B*B+CX
120 B=2*A*B+CY
130 A=AA
140 I=I+1
150 IF A*A+B*B>4 THEN 180
160 IF I<24 THEN 110
170 I=24
180 C=I-1
190 IF C<0 THEN C=0
200 IF C>15 THEN C=15
210 GFX R,X,Y,X+1,Y+1,C
220 NEXT X
230 NEXT Y
240 END
