10 REM MANDELBROT DEMO (320X240, 4BPP, 2X2 BLOCKS)
20 GFX MODE,240
30 GFX OVERLAY,255
40 GFX CLEAR
50 GFX STATUS
60 REM RENDER LOOP
70 FOR Y=0 TO 238 STEP 2
80 CY=(Y-120)/80
90 FOR X=0 TO 318 STEP 2
100 CX=(X-200)/100
110 A=0
120 B=0
130 I=0
140 AA=A*A-B*B+CX
150 B=2*A*B+CY
160 A=AA
170 I=I+1
180 IF A*A+B*B>4 THEN 210
190 IF I<24 THEN 140
200 I=24
210 C=I-1
220 IF C<0 THEN C=0
230 IF C>15 THEN C=15
240 GFX RECT,X,Y,X+1,Y+1,C
250 NEXT X
260 NEXT Y
270 END
